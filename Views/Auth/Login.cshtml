@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null; // 👈 IMPORTANTE: sin layout
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Guías</title>
    
    <!-- Tailwind CSS y Font Awesome -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <!-- Axios -->
</head>
<body class="bg-gray-100">
    <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-blue-50 to-indigo-100 py-12 px-4 sm:px-6 lg:px-8">
        <div class="max-w-md w-full">
            <!-- Logo o Icono -->
            <div class="text-center mb-8">
                <div class="bg-blue-600 p-4 rounded-full inline-flex items-center justify-center w-20 h-20 shadow-lg mb-4">
                    <i class="fa-solid fa-file-pdf text-white text-3xl"></i>
                </div>
                <h2 class="text-3xl font-extrabold text-gray-900">
                    Bienvenido
                </h2>
                <p class="mt-2 text-sm text-gray-600">
                    Inicia sesión para acceder al dashboard
                </p>
            </div>

            <!-- Card del Login -->
            <div class="bg-white rounded-2xl shadow-xl p-8">
                <!-- Mensaje de error -->
                <div id="errorMessage" class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-4 hidden" role="alert">
                    <i class="fa-solid fa-circle-exclamation mr-2"></i>
                    <span id="errorText"></span>
                </div>

                <!-- Loading spinner -->
                <div id="loadingSpinner" class="hidden">
                    <div class="text-center py-4">
                        <i class="fa-solid fa-circle-notch fa-spin text-blue-600 text-3xl"></i>
                        <p class="text-gray-600 mt-2">Verificando credenciales...</p>
                    </div>
                </div>

                <!-- Formulario de login -->
                <form id="loginForm" class="space-y-6">
                    <!-- Campo Identificador -->
                    <div>
                        <label for="identificador" class="block text-sm font-medium text-gray-700 mb-2">
                            Usuario o correo
                        </label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fa-solid fa-envelope text-gray-400"></i>
                            </div>
                            <input id="identificador" name="identificador" type="text" required 
                                class="appearance-none block w-full pl-10 pr-3 py-3 border border-gray-300 rounded-lg placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition duration-150"
                                placeholder="usuario@email.com">
                        </div>
                    </div>

                    <!-- Campo Clave -->
                    <div>
                        <label for="clave" class="block text-sm font-medium text-gray-700 mb-2">
                            Contraseña
                        </label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fa-solid fa-lock text-gray-400"></i>
                            </div>
                            <input id="clave" name="clave" type="password" required 
                                class="appearance-none block w-full pl-10 pr-3 py-3 border border-gray-300 rounded-lg placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition duration-150"
                                placeholder="••••••••">
                        </div>
                    </div>

                    <!-- Botón Login -->
                    <div>
                        <button type="submit" id="loginButton" 
                            class="w-full flex justify-center items-center gap-2 py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition duration-150">
                            <i class="fa-solid fa-arrow-right-to-bracket"></i>
                            Iniciar sesión
                        </button>
                    </div>
                </form>
            </div>

            <p class="mt-8 text-center text-xs text-gray-500">
                &copy; 2026 Tu Empresa. Todos los derechos reservados.
            </p>
        </div>
    </div>

    <!-- Script de login -->
    <script type="module">
        import { login } from '/services/authapi.js';

        const loginForm = document.getElementById('loginForm');
        const loginButton = document.getElementById('loginButton');
        const loadingSpinner = document.getElementById('loadingSpinner');
        const errorMessage = document.getElementById('errorMessage');
        const errorText = document.getElementById('errorText');

        function showError(message) {
            errorText.textContent = message;
            errorMessage.classList.remove('hidden');
            setTimeout(() => {
                errorMessage.classList.add('hidden');
            }, 5000);
        }

        function setLoading(isLoading) {
            if (isLoading) {
                loginButton.disabled = true;
                loginButton.classList.add('opacity-50', 'cursor-not-allowed');
                loadingSpinner.classList.remove('hidden');
            } else {
                loginButton.disabled = false;
                loginButton.classList.remove('opacity-50', 'cursor-not-allowed');
                loadingSpinner.classList.add('hidden');
            }
        }

        loginForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            errorMessage.classList.add('hidden');
            
            const identificador = document.getElementById('identificador').value;
            const clave = document.getElementById('clave').value;
            
            if (!identificador || !clave) {
                showError('Por favor completa todos los campos');
                return;
            }

            try {
                setLoading(true);
                const result = await login(identificador, clave);
                console.log('Login exitoso:', result);
                
                // Redirigir al dashboard
                window.location.href = '/Dashboard/Index';
                
            } catch (error) {
                console.error('Error en login:', error);
                
                if (typeof error === 'string') {
                    showError(error);
                } else if (error.message) {
                    showError(error.message);
                } else {
                    showError('Error al conectar con el servidor');
                }
            } finally {
                setLoading(false);
            }
        });

        // Verificar si ya hay sesión
        if (localStorage.getItem('token')) {
            window.location.href = '/Dashboard/Index';
        }
    </script>
</body>
</html>