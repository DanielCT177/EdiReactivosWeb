@{
    ViewData["Title"] = "Subir Guía PDF";
}

<!-- CSS específico -->
<link rel="stylesheet" href="~/css/guia.css" />

<div class="content-wrapper">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <!-- Tarjeta de subida -->
            <div class="dashboard-card">
                <div class="text-center mb-4">
                    <h1 class="h3 mb-2">Subir Guía PDF</h1>
                    <p class="text-muted">Selecciona o arrastra un archivo PDF para subirlo</p>
                </div>

                <!-- Área de subida -->
                <div class="upload-area mb-4" id="uploadArea">
                    <i class="bi bi-cloud-upload"></i>
                    <h5 class="mt-3">Arrastra tu PDF aquí</h5>
                    <p class="text-muted mb-2">o</p>
                    <button class="btn-upload" id="uploadBtn">
                        <i class="bi bi-folder2-open me-2"></i>Seleccionar archivo
                    </button>
                    <p class="text-muted small mt-3">Solo PDF · Máx 10MB</p>
                    <input type="file" id="fileInput" accept=".pdf" style="display: none;">
                </div>

                <!-- Barra de progreso -->
                <div class="mt-3" id="uploadProgress" style="display: none;">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="small">Subiendo archivo...</span>
                        <span class="small fw-bold" id="progressPercent">0%</span>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar"
                             id="progressBar"
                             role="progressbar"
                             style="width: 0%; background: #00002c; border-radius: 4px;">
                        </div>
                    </div>
                </div>

                <!-- Información del endpoint -->
                <div class="text-center mt-4 pt-3 border-top">
                    <small class="text-muted">
                        <i class="bi bi-hdd-stack me-1"></i>
                        Endpoint: http://localhost:5074/api/files/examples/pdf
                    </small>
                </div>
            </div>

            <!-- Instrucciones -->
            <div class="dashboard-card mt-4">
                <h5 class="mb-3"><i class="bi bi-info-circle me-2" style="color: #00002c;"></i>Instrucciones</h5>
                <ul class="list-unstyled mb-0">
                    <li class="mb-2">
                        <i class="bi bi-check-circle-fill me-2" style="color: #10b981; font-size: 0.9rem;"></i>
                        Haz clic en el área o arrastra un archivo PDF
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-check-circle-fill me-2" style="color: #10b981; font-size: 0.9rem;"></i>
                        El archivo se enviará al endpoint configurado
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-check-circle-fill me-2" style="color: #10b981; font-size: 0.9rem;"></i>
                        Verás una notificación cuando termine
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/guia.js"></script>
}