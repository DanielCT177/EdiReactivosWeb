                    <span>29 Jan</span>
                    <span>30 Jan</span>
                    <span>31 Jan</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Gráfico de líneas para Sales Report
            const ctx = document.getElementById('salesChart').getContext('2d');

            // Generar datos para el gráfico
            const generateData = () => {
                const points = 20;
                const data = [];
                for(let i = 0; i < points; i++) {
                    data.push(Math.floor(Math.random() * 30) + 30);
                }
                return data;
            };

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: Array(20).fill(''),
                    datasets: [{
                        data: generateData(),
                        borderColor: '#4361ee',
                        backgroundColor: 'rgba(67, 97, 238, 0.05)',
                        tension: 0.4,
                        fill: true,
                        pointRadius: 0,
                        borderWidth: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            enabled: false
                        }
                    },
                    scales: {
                        y: {
                            min: 0,
                            max: 100,
                            grid: {
                                color: '#f1f5f9'
                            },
                            ticks: {
                                stepSize: 10,
                                callback: function(value) {
                                    return value + '%';
                                }
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            }
                        }
                    }
                }
            });
        });
    </script>
}