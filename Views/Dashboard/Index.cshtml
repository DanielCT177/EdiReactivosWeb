@{
    ViewData["Title"] = "Dashboard";
}

<!-- 👇 AGREGAR ESTAS DOS LÍNEAS AQUÍ 👇 -->
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<!-- TARJETAS DE ESTADÍSTICAS -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <!-- Card 1 -->
    <div class="bg-white rounded-xl shadow-lg p-6 border-l-4 border-blue-500">
        <div class="flex justify-between items-start">
            <div>
                <p class="text-gray-500 text-sm">Total Guías</p>
                <h3 class="text-2xl font-bold text-gray-800 mt-1">156</h3>
                <p class="text-green-600 text-sm mt-2">+12% este mes</p>
            </div>
            <div class="bg-blue-100 p-3 rounded-lg">
                <i class="fa-solid fa-file-pdf text-blue-600 text-xl"></i>
            </div>
        </div>
    </div>

    <!-- Card 2 -->
    <div class="bg-white rounded-xl shadow-lg p-6 border-l-4 border-green-500">
        <div class="flex justify-between items-start">
            <div>
                <p class="text-gray-500 text-sm">Subidas</p>
                <h3 class="text-2xl font-bold text-gray-800 mt-1">23</h3>
                <p class="text-green-600 text-sm mt-2">+8% este mes</p>
            </div>
            <div class="bg-green-100 p-3 rounded-lg">
                <i class="fa-solid fa-cloud-arrow-up text-green-600 text-xl"></i>
            </div>
        </div>
    </div>

    <!-- Card 3 -->
    <div class="bg-white rounded-xl shadow-lg p-6 border-l-4 border-purple-500">
        <div class="flex justify-between items-start">
            <div>
                <p class="text-gray-500 text-sm">Descargas</p>
                <h3 class="text-2xl font-bold text-gray-800 mt-1">1,245</h3>
                <p class="text-green-600 text-sm mt-2">+28% este mes</p>
            </div>
            <div class="bg-purple-100 p-3 rounded-lg">
                <i class="fa-solid fa-download text-purple-600 text-xl"></i>
            </div>
        </div>
    </div>

    <!-- Card 4 -->
    <div class="bg-white rounded-xl shadow-lg p-6 border-l-4 border-yellow-500">
        <div class="flex justify-between items-start">
            <div>
                <p class="text-gray-500 text-sm">Usuarios</p>
                <h3 class="text-2xl font-bold text-gray-800 mt-1">42</h3>
                <p class="text-green-600 text-sm mt-2">+5% este mes</p>
            </div>
            <div class="bg-yellow-100 p-3 rounded-lg">
                <i class="fa-solid fa-users text-yellow-600 text-xl"></i>
            </div>
        </div>
    </div>
</div>

<!-- TABLA RECIENTE -->
<div class="bg-white rounded-xl shadow-lg p-6">
    <h2 class="text-lg font-semibold text-gray-800 mb-4">Últimas guías subidas</h2>
    
    <table class="w-full">
        <thead>
            <tr class="border-b border-gray-200">
                <th class="text-left py-3 text-sm font-semibold text-gray-600">Nombre</th>
                <th class="text-left py-3 text-sm font-semibold text-gray-600">Tamaño</th>
                <th class="text-left py-3 text-sm font-semibold text-gray-600">Fecha</th>
                <th class="text-left py-3 text-sm font-semibold text-gray-600">Acciones</th>
            </tr>
        </thead>
        <tbody>
            <tr class="border-b border-gray-100 hover:bg-gray-50">
                <td class="py-3">
                    <div class="flex items-center gap-2">
                        <i class="fa-solid fa-file-pdf text-red-500"></i>
                        <span>Guía de reactivos.pdf</span>
                    </div>
                </td>
                <td class="py-3 text-gray-600">2.4 MB</td>
                <td class="py-3 text-gray-600">12/03/2026</td>
                <td class="py-3">
                    <div class="flex gap-2">
                        <button class="text-gray-400 hover:text-blue-600"><i class="fa-solid fa-eye"></i></button>
                        <button class="text-gray-400 hover:text-green-600"><i class="fa-solid fa-download"></i></button>
                        <button class="text-gray-400 hover:text-red-600"><i class="fa-solid fa-trash"></i></button>
                    </div>
                </td>
            </tr>
            <tr class="border-b border-gray-100 hover:bg-gray-50">
                <td class="py-3">
                    <div class="flex items-center gap-2">
                        <i class="fa-solid fa-file-pdf text-red-500"></i>
                        <span>Manual de laboratorio.pdf</span>
                    </div>
                </td>
                <td class="py-3 text-gray-600">5.1 MB</td>
                <td class="py-3 text-gray-600">11/03/2026</td>
                <td class="py-3">
                    <div class="flex gap-2">
                        <button class="text-gray-400 hover:text-blue-600"><i class="fa-solid fa-eye"></i></button>
                        <button class="text-gray-400 hover:text-green-600"><i class="fa-solid fa-download"></i></button>
                        <button class="text-gray-400 hover:text-red-600"><i class="fa-solid fa-trash"></i></button>
                    </div>
                </td>
            </tr>
        </tbody>
    </table>
</div>