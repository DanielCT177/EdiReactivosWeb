@{
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    bool isLoginPage = currentController.Equals("Auth", StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Guías</title>
    
    <!-- Tailwind CSS y Font Awesome -->
    <link href="~/css/site.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-100">

    <!-- Script de verificación de autenticación -->
    <script>
        (function() {
            const token = localStorage.getItem('token');
            const currentPath = window.location.pathname.toLowerCase();
            
            if (!token && !currentPath.includes('/auth/login')) {
                window.location.href = '/Auth/Login';
            }
            
            if (token && currentPath.includes('/auth/login')) {
                window.location.href = '/Dashboard/Index';
            }
        })();
    </script>

    @if (!isLoginPage)
    {
        <!-- Sidebar -->
        @await Html.PartialAsync("_Sidebar")
        
        <!-- CONTENIDO PRINCIPAL -->
        <div class="ml-64 min-h-screen bg-gray-100">
            <main class="p-8">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <!-- Para login, sin sidebar -->
        <main>
            @RenderBody()
        </main>
    }
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>