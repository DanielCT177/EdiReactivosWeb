@{
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    bool isLoginPage = currentController.Equals("Auth", StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Guías</title>
    
    <!-- Tailwind CSS y Font Awesome -->
    <link href="~/css/site.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <!-- Cargar el sistema de roles -->
    <script type="import" src="/js/roles/index.js"></script>
</head>
<body class="bg-gray-100">

    <!-- Script de verificación de autenticación y ROUTE GUARD -->
    <script type="module">
        import { isAuthenticated, routeGuard, redirectBasedOnRole, logout } from '/js/roles/guards.js';
        
        // Hacer logout disponible globalmente
        window.logout = logout;
        
        (function() {
            const token = localStorage.getItem('token');
            const currentPath = window.location.pathname.toLowerCase();
            
            console.log('🔍 Verificando:', { token, currentPath });
            
            // Verificar autenticación
            if (!token && !currentPath.includes('/auth/login')) {
                console.log('➡️ No autenticado, redirigiendo a login');
                window.location.href = '/Auth/Login';
                return;
            }
            
            // Si está en login pero ya tiene token, redirigir según rol
            if (token && currentPath.includes('/auth/login')) {
                console.log('➡️ Ya autenticado en login, redirigiendo según rol');
                redirectBasedOnRole(); // ✅ USA roleRedirects
                return;
            }
            
            // Ejecutar routeGuard para verificar acceso a la ruta actual
            if (token && !currentPath.includes('/auth/login')) {
                console.log('➡️ Verificando acceso a ruta:', currentPath);
                routeGuard(); // ✅ USA isRouteAllowed
            }
        })();
    </script>

    <!-- Script de respaldo por si el módulo falla -->
    <script>
        setTimeout(function() {
            if (typeof window.logout !== 'function') {
                window.logout = function() {
                    localStorage.removeItem('token');
                    localStorage.removeItem('usuario');
                    localStorage.removeItem('correo');
                    localStorage.removeItem('role');
                    sessionStorage.clear();
                    window.location.href = '/Auth/Login';
                };
            }
        }, 1000);
    </script>

    @if (!isLoginPage)
    {
        <!-- Sidebar -->
        @await Html.PartialAsync("_Sidebar")
        
        <!-- CONTENIDO PRINCIPAL -->
        <div class="ml-64 min-h-screen bg-gray-100">
            <main class="p-8">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <!-- Para login, sin sidebar -->
        <main>
            @RenderBody()
        </main>
    }
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>