<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Blueberry CRM</title>

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Nuestro CSS personalizado -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="dashboard-wrapper">
        <!-- SIDEBAR con color #00002c -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <a href="/" class="brand-logo">
                    <div class="brand-icon">
                        <i class="bi bi-cpu"></i>
                    </div>
                    <span class="brand-text">Blueberry CRM</span>
                </a>
            </div>

            <nav class="sidebar-nav">
                <!-- Overview Section -->
                <div class="sidebar-section">
                    <div class="sidebar-section-title">OVERVIEW</div>
                    <ul class="sidebar-menu">
                        <li>
                            <a href="/Dashboard" class="sidebar-link active">
                                <i class="bi bi-speedometer2"></i>
                                <span>Dashboard</span>
                            </a>
                        </li>
                        <li>
                            <a href="#" class="sidebar-link">
                                <i class="bi bi-graph-up"></i>
                                <span>Analytics</span>
                            </a>
                        </li>
                        <li>
                            <a href="#" class="sidebar-link">
                                <i class="bi bi-people"></i>
                                <span>Users</span>
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- PRODUCTS Section -->
                <div class="sidebar-section">
                    <div class="sidebar-section-title">PRODUCTS</div>
                    <ul class="sidebar-menu">
                        <li>
                            <a href="#" class="sidebar-link">
                                <i class="bi bi-box"></i>
                                <span>All Products</span>
                            </a>
                        </li>
                        <li>
                            <a href="#" class="sidebar-link">
                                <i class="bi bi-tags"></i>
                                <span>Categories</span>
                            </a>
                        </li>
                        <li>
                            <a href="#" class="sidebar-link">
                                <i class="bi bi-star"></i>
                                <span>Top Selling</span>
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- SALES Section -->
                <div class="sidebar-section">
                    <div class="sidebar-section-title">SALES</div>
                    <ul class="sidebar-menu">
                        <li>
                            <a href="#" class="sidebar-link">
                                <i class="bi bi-cash-stack"></i>
                                <span>Orders</span>
                            </a>
                        </li>
                        <li>
                            <a href="#" class="sidebar-link">
                                <i class="bi bi-receipt"></i>
                                <span>Invoices</span>
                            </a>
                        </li>
                        <li>
                            <a href="#" class="sidebar-link">
                                <i class="bi bi-percent"></i>
                                <span>Discounts</span>
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- EVENTS Section -->
                <div class="sidebar-section">
                    <div class="sidebar-section-title">EVENTS</div>
                    <ul class="sidebar-menu">
                        <li>
                            <a href="#" class="sidebar-link">
                                <i class="bi bi-calendar"></i>
                                <span>Calendar</span>
                            </a>
                        </li>
                        <li>
                            <a href="#" class="sidebar-link">
                                <i class="bi bi-clock"></i>
                                <span>Upcoming</span>
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- SETTINGS Section -->
                <div class="sidebar-section">
                    <div class="sidebar-section-title">SETTINGS</div>
                    <ul class="sidebar-menu">
                        <li>
                            <a href="#" class="sidebar-link">
                                <i class="bi bi-gear"></i>
                                <span>Settings</span>
                            </a>
                        </li>
                        <li>
                            <a href="#" class="sidebar-link">
                                <i class="bi bi-shield"></i>
                                <span>Security</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <!-- Perfil en el sidebar (parte inferior) -->
            <div class="sidebar-footer">
                <div class="user-info">
                    <div class="user-avatar">
                        <span>JD</span>
                    </div>
                    <div class="user-details">
                        <div class="user-name">John Doe</div>
                        <div class="user-role">Administrator</div>
                    </div>
                    <i class="bi bi-three-dots-vertical"></i>
                </div>
            </div>
        </aside>

        <!-- CONTENIDO PRINCIPAL -->
        <main class="main-content" id="mainContent">
            <!-- Barra superior -->
            <div class="top-bar">
                <div class="top-bar-left">
                    <button class="toggle-sidebar" id="toggleSidebar">
                        <i class="bi bi-list"></i>
                    </button>
                    <h2 class="page-title">@ViewData["Title"]</h2>
                </div>

                <div class="top-bar-right">
                    <!-- Search -->
                    <div class="search-box">
                        <i class="bi bi-search"></i>
                        <input type="text" placeholder="Search...">
                    </div>

                    <!-- Notifications -->
                    <div class="notification-icon">
                        <i class="bi bi-bell"></i>
                        <span class="notification-badge">3</span>
                    </div>

                    <!-- Messages -->
                    <div class="notification-icon">
                        <i class="bi bi-chat"></i>
                        <span class="notification-badge">5</span>
                    </div>

                    <!-- Theme toggle (opcional) -->
                    <div class="theme-toggle">
                        <i class="bi bi-moon"></i>
                    </div>
                </div>
            </div>

            <!-- Contenido de la página -->
            <div class="content-wrapper">
                @RenderBody()
            </div>
        </main>
    </div>

    <!-- Botón para móvil -->
    <button class="toggle-sidebar-mobile" id="mobileToggle">
        <i class="bi bi-list"></i>
    </button>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function() {
            const sidebar = $('#sidebar');
            const mainContent = $('#mainContent');
            const toggleBtn = $('#toggleSidebar');
            const mobileToggle = $('#mobileToggle');

            // Función para colapsar/expandir sidebar en desktop
            toggleBtn.click(function() {
                sidebar.toggleClass('collapsed');
                mainContent.toggleClass('expanded');

                const icon = toggleBtn.find('i');
                if (sidebar.hasClass('collapsed')) {
                    icon.removeClass('bi-list').addClass('bi-arrow-right');
                } else {
                    icon.removeClass('bi-arrow-right').addClass('bi-list');
                }
            });

            // Botón para móvil
            mobileToggle.click(function() {
                sidebar.toggleClass('mobile-open');
            });

            // Cerrar sidebar al hacer click fuera en móvil
            $(document).on('click', function(e) {
                if ($(window).width() <= 768) {
                    if (!sidebar.is(e.target) && sidebar.has(e.target).length === 0 && !mobileToggle.is(e.target) && mobileToggle.has(e.target).length === 0) {
                        sidebar.removeClass('mobile-open');
                    }
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>