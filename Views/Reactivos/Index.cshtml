@{
    ViewData["Title"] = "Registrar Materias y Temas";
}
<!-- Agrega esto en el <head> de tu página -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
<script src="~/services/subjetapi.js"></script>
  <link rel="stylesheet" href="~/css/reactivos/reactivos-styles.css">

<style>
  
</style>

<div class="p-1">
    
        <!-- ===== HEADER MEJORADO ===== -->
        <div class="bg-gradient-to-r from-[#00002c] to-[#1a1a5c] rounded-2xl shadow-xl mb-8 overflow-hidden animate-fade-in">
            <div class="relative px-8 py-10">
                <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -mr-20 -mt-20"></div>
                <div class="absolute bottom-0 left-0 w-48 h-48 bg-white/5 rounded-full -ml-16 -mb-16"></div>
                
                <div class="relative z-10 flex items-center justify-between">
                    <div>
                        <h1 class="text-4xl font-bold text-white mb-2">Registro de Materias</h1>
                        <p class="text-white/80 text-lg">Gestión de materias y temas con reactivos</p>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="bg-white/20 backdrop-blur-sm rounded-xl px-4 py-2 flex items-center gap-2">
                            <i class="fa-solid fa-book-open text-white"></i>
                            <span class="text-white font-medium" id="totalMateriasHeader">0 Materias</span>
                        </div>
                        <div class="bg-white/20 backdrop-blur-sm rounded-xl px-4 py-2 flex items-center gap-2">
                            <i class="fa-solid fa-file-lines text-white"></i>
                            <span class="text-white font-medium" id="totalReactivosHeader">0 Reactivos</span>
                        </div>
                        <button onclick="location.href='/Dashboard/Index'" class="px-4 py-2 bg-white/20 backdrop-blur-lg text-white rounded-xl hover:bg-white/30 transition-all flex items-center gap-2">
                            <i class="fa-solid fa-arrow-left"></i>
                            Volver
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Mensajes de alerta -->
        <div id="successMessage" class="hidden mb-6 p-4 bg-green-100 border-l-4 border-green-500 text-green-700 rounded-lg animate-fade-in">
            <div class="flex items-center gap-3">
                <i class="fa-solid fa-circle-check text-green-500"></i>
                <span id="successText"></span>
            </div>
        </div>

        <div id="errorMessage" class="hidden mb-6 p-4 bg-red-100 border-l-4 border-red-500 text-red-700 rounded-lg animate-fade-in">
            <div class="flex items-center gap-3">
                <i class="fa-solid fa-circle-exclamation text-red-500"></i>
                <span id="errorText"></span>
            </div>
        </div>

        <!-- Contenido principal -->
        <div class="grid lg:grid-cols-2 gap-8">
            <!-- Panel IZQUIERDO - FORMULARIO -->
            <div class="lg:col-span-1">
                <div class="glass-card rounded-2xl p-6 sticky top-6 animate-slide-in h-full">
                    <h2 class="text-xl font-bold text-gray-800 mb-6 flex items-center gap-2">
                        <i class="fa-solid fa-plus-circle text-blue-600"></i>
                        Agregar Materia
                    </h2>

                    <form id="materiaForm" class="space-y-4">
                        <!-- Nombre de la Carrera -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                <i class="fa-solid fa-graduation-cap mr-2 text-blue-600"></i>
                                Nombre de la Carrera
                            </label>
                            <input type="text" id="carreraNombre" required
                                class="input-focus w-full px-4 py-3 rounded-xl outline-none bg-gray-50"
                                placeholder="Ej: Ingeniería en Sistemas">
                        </div>

                        <!-- Nombre de la materia -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                <i class="fa-solid fa-book mr-2 text-blue-600"></i>
                                Nombre de la Materia
                            </label>
                            <input type="text" id="materiaNombre" required
                                class="input-focus w-full px-4 py-3 rounded-xl outline-none bg-gray-50"
                                placeholder="Ej: Programación Orientada a Objetos">
                        </div>

                        <!-- Temas dinámicos -->
                        <div class="temas-container">
                            <div class="flex items-center justify-between mb-2">
                                <label class="block text-sm font-medium text-gray-700">
                                    <i class="fa-solid fa-list mr-2 text-blue-600"></i>
                                    Temas y Reactivos
                                </label>
                                <div class="flex gap-2">
                                    <span class="bg-blue-100 text-blue-600 text-xs px-3 py-1 rounded-full" id="temasCount">0 temas</span>
                                    <span class="temas-count-badge" id="scrollInfo">0 en scroll</span>
                                </div>
                            </div>
                            
                            <!-- CONTENEDOR CON SCROLL -->
                            <div id="temasContainer" class="temas-scroll-container">
                                <!-- Los temas se agregan aquí -->
                            </div>

                            <!-- Botón para agregar temas -->
                            <div class="flex gap-2 mt-3">
                                <button type="button" onclick="agregarTema()" 
                                    class="w-full px-4 py-3 bg-gray-100 text-gray-700 rounded-xl hover:bg-gray-200 transition-all flex items-center justify-center gap-2">
                                    <i class="fa-solid fa-plus"></i>
                                    Agregar Tema
                                </button>
                            </div>
                        </div>

                        <!-- Botón guardar materia -->
                        <button type="button" onclick="guardarMateria()" 
                            class="btn-success w-full text-white py-3 px-4 rounded-xl font-semibold flex items-center justify-center gap-2 mt-4">
                            <i class="fa-solid fa-save"></i>
                            Guardar Materia
                        </button>
                    </form>
                </div>
            </div>

            <!-- Panel DERECHO - LISTA DE MATERIAS -->
            <div class="lg:col-span-1">
                <div class="glass-card rounded-2xl p-6 animate-slide-in h-full flex flex-col" style="animation-delay: 0.2s;">
                    <!-- Sección de Materias Registradas -->
                    <div class="flex-1">
                        <div class="flex items-center justify-between mb-6">
                            <h2 class="text-xl font-bold text-gray-800 flex items-center gap-2">
                                <i class="fa-solid fa-layer-group text-blue-600"></i>
                                Materias Registradas
                            </h2>
                            <div class="flex gap-2">
                                <span id="carreraDisplay" class="bg-purple-100 text-purple-600 px-3 py-1 rounded-full text-sm font-medium">Ingenieria en Sistemas</span>
                                <span id="materiasCount" class="bg-blue-100 text-blue-600 px-3 py-1 rounded-full text-sm font-medium">0</span>
                            </div>
                        </div>

                        <!-- Lista de materias -->
                        <div id="materiasLista" class="materias-scroll-container space-y-4 pr-2" style="max-height: 350px;">
                            <div class="text-center text-gray-500 py-8">
                                <i class="fa-solid fa-folder-open text-4xl mb-3 text-gray-300"></i>
                                <p>No hay materias registradas</p>
                                <p class="text-sm">Agrega materias usando el formulario</p>
                            </div>
                        </div>
                    </div>

                    <!-- Botón enviar todas -->
                    <div class="mt-4">
                        <button onclick="enviarMaterias()" id="btnEnviar" disabled
                            class="btn-primary w-full text-white py-4 px-4 rounded-xl font-semibold flex items-center justify-center gap-3 opacity-50 cursor-not-allowed transition-all">
                            <i class="fa-solid fa-paper-plane"></i>
                            Generar Excel
                            <span id="totalReactivos" class="bg-white/20 px-2 py-1 rounded-lg text-sm">0</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== SECCIÓN EXCEL ===== -->
        <div class="excel-section animate-fade-in" style="animation-delay: 0.3s;">
            <div class="glass-card rounded-2xl p-6">
                <div class="flex justify-between items-center mb-6">
                    <div class="flex items-center gap-3">
                        <div class="w-12 h-12 bg-gradient-to-r from-green-600/10 to-green-700/10 rounded-xl flex items-center justify-center">
                            <i class="fa-solid fa-file-excel text-green-600 text-xl"></i>
                        </div>
                        <div>
                            <h2 class="text-2xl font-bold text-gray-800">Archivos Excel Generados</h2>
                            <p class="text-gray-500">Documentos generados desde materias y temas</p>
                        </div>
                        <span class="bg-green-100 text-green-600 text-xs px-3 py-1.5 rounded-full font-medium">Generados desde materias</span>
                        <span class="bg-gray-100 text-gray-600 text-xs px-3 py-1.5 rounded-full font-medium" id="excelCountBadge">0 documentos</span>
                    </div>
                    <div class="flex gap-3">
                        <button onclick="cargarArchivosExcel()" class="btn-info text-white px-4 py-2 rounded-xl flex items-center gap-2 text-sm btn-shine">
                            <i class="fa-solid fa-rotate-right"></i>
                            Actualizar
                        </button>
                    </div>
                </div>

                <!-- Tabla Excel -->
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="bg-gradient-to-r from-gray-100 to-gray-50">
                            <tr class="text-left text-sm text-gray-600">
                                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Archivo</th>
                                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Fecha</th>
                                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">ID</th>
                                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="excelFilesTableBody" class="divide-y divide-gray-100">
                            <tr id="loadingExcelRow">
                                <td colspan="4" class="px-6 py-8 text-center">
                                    <div class="flex flex-col items-center justify-center">
                                        <i class="fa-solid fa-spinner fa-spin text-green-600 text-3xl mb-3"></i>
                                        <p class="text-gray-500">Cargando archivos Excel...</p>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Paginación -->
                <div class="mt-6 flex items-center justify-between p-4 bg-gray-50 rounded-xl">
                    <div class="flex items-center gap-4">
                        <p class="text-sm text-gray-500" id="excelPaginationInfo">
                            <i class="fa-regular fa-file-excel mr-2 text-green-500"></i>
                            Mostrando <span id="paginationStart">0</span> - <span id="paginationEnd">0</span> de <span id="paginationTotal">0</span> archivos
                        </p>
                    </div>
                    <div class="pagination-container" id="excelPaginationControls"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== MODAL DE CONFIRMACIÓN ===== -->
    <div id="deleteConfirmModal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden modal-transition">
        <div class="bg-white rounded-2xl max-w-md w-full mx-4 overflow-hidden shadow-2xl transform transition-all duration-300 scale-95" id="deleteModalContent">
            <div class="bg-gradient-to-r from-red-500 to-red-600 px-6 py-5 shake-animation">
                <div class="flex items-center gap-3">
                    <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center">
                        <i class="fa-solid fa-triangle-exclamation text-white text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-white font-bold text-xl">¡Atención!</h3>
                        <p class="text-white/80 text-sm">Esta acción es irreversible</p>
                    </div>
                </div>
            </div>
            
            <div class="p-8">
                <div class="flex flex-col items-center text-center">
                    <div class="w-24 h-24 bg-gradient-to-br from-red-50 to-red-100 rounded-2xl flex items-center justify-center mb-6 delete-icon">
                        <i class="fa-solid fa-trash-can text-red-500 text-4xl"></i>
                    </div>
                    
                    <h4 class="text-gray-800 text-2xl font-bold mb-2">¿Eliminar archivo?</h4>
                    <p class="text-gray-500 text-base mb-4">Esta acción no se puede deshacer y el archivo se perderá permanentemente.</p>
                    
                    <div class="bg-gray-50 border-2 border-gray-200 rounded-xl p-4 w-full mb-2">
                        <p class="text-gray-400 text-xs mb-1">Documento seleccionado:</p>
                        <p class="text-gray-800 font-mono font-semibold text-sm break-all" id="deleteFileName">nombre-del-archivo.xlsx</p>
                    </div>
                    
                    <div class="flex items-center gap-2 text-amber-600 bg-amber-50 px-4 py-2 rounded-lg mt-2">
                        <i class="fa-solid fa-circle-exclamation text-sm"></i>
                        <p class="text-xs font-medium">Esta operación no se puede revertir</p>
                    </div>
                </div>
            </div>
            
            <div class="px-6 py-5 bg-gray-50 flex justify-end gap-3 border-t border-gray-100">
                <button onclick="closeDeleteModal()" class="px-5 py-2.5 border-2 border-gray-200 rounded-xl text-gray-600 font-medium hover:bg-gray-100 hover:border-gray-300 transition-all flex items-center gap-2">
                    <i class="fa-solid fa-times"></i>
                    Cancelar
                </button>
                <button onclick="confirmDelete()" class="px-5 py-2.5 bg-gradient-to-r from-red-500 to-red-600 text-white font-medium rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-0.5 flex items-center gap-2 btn-shine">
                    <i class="fa-solid fa-trash"></i>
                    Eliminar permanentemente
                </button>
            </div>
        </div>
    
</div>

   @section Scripts {
            <script src="~/js/reactivos/reactivos-script.js"></script>
    }